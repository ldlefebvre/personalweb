---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import { skillGroups } from "@/data/skills";
---

<Section id="skills" class="border-t border-border/50">
  <SectionHeading
    eyebrow="Toolbox"
    title="Skills, grouped by how I use them"
    id="skills-heading"
  />
  <p class="mt-3 max-w-2xl text-text-muted">
    Not a wall of logos — every tool here is something I've shipped real products with.
  </p>

  <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {
      skillGroups.map((group, i) => (
        <div class="reveal surface-card flex flex-col p-6" data-reveal-delay={i * 70}>
          <h3 class="font-display text-lg font-semibold text-primary">{group.title}</h3>
          <p class="mt-1 text-sm text-text-subtle">{group.blurb}</p>
          <ul class="mt-4 flex flex-1 flex-wrap content-start gap-2">
            {group.skills.map((s) => (
              <li class="rounded-lg border border-border bg-surface-2/50 px-3 py-1.5 text-sm text-text-muted">
                {s}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
