---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";

const interests = [
  {
    title: "Wine, seriously",
    body: "WSET-trained and deep into blind tasting — the obsession that became Sensium.",
  },
  {
    title: "Alpine skiing",
    body: "A lifelong competitive skier; comfortable making fast decisions under pressure.",
  },
  {
    title: "Powerlifting",
    body: "Consistency, progressive overload, and showing up — the same loop as shipping software.",
  },
];
---

<Section id="about" class="border-t border-border/50">
  <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div class="reveal">
      <SectionHeading eyebrow="Beyond code" title="The why behind the work" id="about-heading" />
      <p class="mt-5 text-lead text-text-muted">
        I'm an engineer who likes building things I'd actually use. The clearest
        example: years of studying wine the hard way led me to build Sensium — so
        the discipline and curiosity outside of code feed directly back into it.
      </p>
      <p class="mt-4 text-text-muted">
        Outside the editor you'll find me on a ski slope, under a barbell, or
        nose-deep in a glass trying to call the grape blind.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
      {
        interests.map((it, i) => (
          <div class="reveal surface-card p-5" data-reveal-delay={i * 80}>
            <h3 class="font-display font-semibold text-primary">{it.title}</h3>
            <p class="mt-1.5 text-sm text-text-muted">{it.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</Section>
