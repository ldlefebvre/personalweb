---
/*
  Ambient hero background. A cinematic, muted, looping clip sits at the base
  (≈3.4 MB MP4, served from /public) with a static poster for instant paint and
  a prefers-reduced-motion fallback. Brand-tinted dark overlays keep the hero
  text fully readable. Two soft drifting gradient orbs add the green glow on top.
  Decorative only (aria-hidden); orb drift is disabled under reduced motion via
  the global .animate-float guard.
*/
---

<div aria-hidden="true" class="hero-bg pointer-events-none absolute inset-0 overflow-hidden">
  <img
    src="/media/hero-poster.jpg"
    alt=""
    class="absolute inset-0 size-full object-cover"
    fetchpriority="low"
  />

  <video
    class="hero-bg__video absolute inset-0 size-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster="/media/hero-poster.jpg"
  >
    <source src="/media/hero.mp4" type="video/mp4" />
  </video>

  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, rgba(6,26,23,0.55) 0%, rgba(6,26,23,0.78) 55%, var(--color-bg) 100%);"
  >
  </div>
  <div
    class="absolute inset-0"
    style="background: linear-gradient(90deg, rgba(6,26,23,0.88) 0%, rgba(6,26,23,0.5) 52%, rgba(6,26,23,0.18) 100%);"
  >
  </div>

  <div
    class="animate-float absolute -right-24 -top-28 size-[34rem] rounded-full blur-[90px]"
    style="background: radial-gradient(circle, rgba(46,230,166,0.18), transparent 65%); animation-duration: 9s;"
  >
  </div>
  <div
    class="animate-float absolute -bottom-32 -left-24 size-[30rem] rounded-full blur-[100px]"
    style="background: radial-gradient(circle, rgba(21,214,148,0.12), transparent 65%); animation-duration: 11s; animation-delay: -3s;"
  >
  </div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    .hero-bg__video {
      display: none;
    }
  }
</style>
