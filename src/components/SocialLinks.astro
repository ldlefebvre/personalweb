---
import Icon from "@/components/ui/Icon.astro";
import { site } from "@/data/site";

interface Props {
  class?: string;
  size?: number;
}
const { class: className = "", size = 20 } = Astro.props;
const socials = [site.socials.github, site.socials.linkedin, site.socials.instagram];
---

<ul class:list={["flex items-center gap-2", className]}>
  {
    socials.map((s) => (
      <li>
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          class="grid size-10 place-items-center rounded-full border border-border bg-surface/40 text-text-muted transition-all duration-200 hover:-translate-y-0.5 hover:border-primary hover:text-primary"
        >
          <Icon name={s.icon as any} size={size} />
        </a>
      </li>
    ))
  }
</ul>
