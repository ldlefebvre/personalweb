---
interface Props {
  eyebrow?: string;
  title: string;
  id?: string;
  class?: string;
  align?: "left" | "center";
}
const { eyebrow, title, id, class: className = "", align = "left" } = Astro.props;
---

<div class:list={[align === "center" && "text-center", className]}>
  {
    eyebrow && (
      <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-primary">
        {eyebrow}
      </p>
    )
  }
  <h2 id={id} class="mt-3 text-h2">{title}</h2>
</div>
