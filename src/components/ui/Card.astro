---
interface Props {
  href?: string;
  class?: string;
  interactive?: boolean;
  target?: string;
  rel?: string;
}
const { href, class: className = "", interactive = false, ...rest } = Astro.props;
const Tag = href ? "a" : "div";
const interactiveCls =
  href || interactive
    ? "transition-all duration-300 hover:border-border-strong hover:-translate-y-1 hover:shadow-glow-soft"
    : "";
---

<Tag
  class:list={["surface-card block p-6 sm:p-8", interactiveCls, className]}
  href={href}
  {...rest}
>
  <slot />
</Tag>
