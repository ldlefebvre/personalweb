---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Tag from "@/components/ui/Tag.astro";
import Icon from "@/components/ui/Icon.astro";
import Gallery from "@/components/work/Gallery.astro";
import ProjectSchema from "@/components/seo/ProjectSchema.astro";
import { projectImage } from "@/lib/images";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).sort(
    (a, b) => a.data.order - b.data.order,
  );
  return projects.map((project, i) => ({
    params: { slug: project.id },
    props: {
      project,
      prev: i > 0 ? projects[i - 1] : projects[projects.length - 1],
      next: i < projects.length - 1 ? projects[i + 1] : projects[0],
    },
  }));
}

const { project, prev, next } = Astro.props;
const d = project.data;
const { Content } = await render(project);
const logo = await projectImage(d.logo);
const headerStyle = `background:
  radial-gradient(80% 120% at 50% -10%, ${d.accent}33, transparent 70%);`;
---

<BaseLayout title={d.title} description={d.summary} type="article">
  <ProjectSchema slot="head" project={project} />
  <article>
    <header class="relative overflow-hidden border-b border-border/60" style={headerStyle}>
      <Container class="py-14 sm:py-20">
        <a
          href="/work"
          class="inline-flex items-center gap-1.5 text-sm text-text-muted transition-colors hover:text-primary"
        >
          <Icon name="chevron-left" size={16} /> All work
        </a>

        <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
          <div>
            <p class="font-mono text-sm uppercase tracking-[0.2em] text-primary">{d.role}</p>
            <h1 class="mt-3 text-h1">{d.title}</h1>
            <p class="mt-3 max-w-2xl text-lead text-text-muted">{d.summary}</p>
          </div>
          <Image
            src={logo}
            alt={`${d.title} logo`}
            widths={[180, 260]}
            sizes="220px"
            class="h-16 w-auto max-w-[16rem] object-contain lg:h-20"
          />
        </div>

        {
          d.metrics.length > 0 && (
            <dl class="mt-10 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-4">
              {d.metrics.map((m) => (
                <div class="bg-surface/80 p-5">
                  <dt class="font-mono text-2xl font-semibold text-primary">{m.value}</dt>
                  <dd class="mt-1 text-sm text-text-muted">{m.label}</dd>
                </div>
              ))}
            </dl>
          )
        }

        {
          d.links.length > 0 && (
            <div class="mt-8 flex flex-wrap gap-3">
              {d.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[
                    "inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all duration-200 hover:-translate-y-0.5",
                    link.primary
                      ? "bg-primary text-ink shadow-glow-soft hover:bg-primary-strong"
                      : "border border-border-strong text-text hover:border-primary hover:text-primary",
                  ]}
                >
                  {link.label}
                  <Icon name="external" size={15} />
                </a>
              ))}
            </div>
          )
        }
      </Container>
    </header>

    <Container class="py-14 sm:py-16">
      <div class="grid gap-12 lg:grid-cols-[1fr_16rem] lg:gap-16">
        <div class="case-prose order-2 max-w-2xl lg:order-1">
          <Content />
        </div>

        <aside class="order-1 lg:order-2 lg:pt-2">
          <div class="surface-card p-6 lg:sticky lg:top-28">
            <h2 class="font-mono text-xs uppercase tracking-widest text-text-subtle">Stack</h2>
            <div class="mt-3 flex flex-wrap gap-1.5">
              {d.stack.map((s) => <Tag>{s}</Tag>)}
            </div>
            {
              d.platforms.length > 0 && (
                <>
                  <h2 class="mt-6 font-mono text-xs uppercase tracking-widest text-text-subtle">
                    Platforms
                  </h2>
                  <ul class="mt-3 flex flex-wrap gap-1.5">
                    {d.platforms.map((p) => (
                      <li class="rounded-md bg-surface-2/70 px-2.5 py-1 text-xs text-text-muted">
                        {p}
                      </li>
                    ))}
                  </ul>
                </>
              )
            }
            <h2 class="mt-6 font-mono text-xs uppercase tracking-widest text-text-subtle">Role</h2>
            <p class="mt-2 text-sm text-text-muted">{d.role}</p>
            <p class="mt-1 font-mono text-xs text-text-subtle">{d.period}</p>
          </div>
        </aside>
      </div>

      {
        d.gallery.length > 0 && (
          <section class="mt-16" aria-labelledby="gallery-heading">
            <div class="flex flex-wrap items-end justify-between gap-3">
              <h2 id="gallery-heading" class="text-h3">Gallery</h2>
              {d.galleryNote && <p class="max-w-md text-sm text-text-subtle">{d.galleryNote}</p>}
            </div>
            <div class="mt-8">
              <Gallery items={d.gallery} accent={d.accent} />
            </div>
          </section>
        )
      }
    </Container>

    <nav
      class="border-t border-border/60"
      aria-label="More projects"
    >
      <Container class="grid gap-px sm:grid-cols-2">
        <a
          href={`/work/${prev.id}`}
          class="group flex items-center gap-3 py-8 pr-6 transition-colors hover:text-primary sm:border-r sm:border-border/60"
        >
          <Icon name="chevron-left" size={20} class="text-text-subtle transition-transform group-hover:-translate-x-1" />
          <span>
            <span class="block font-mono text-xs uppercase tracking-widest text-text-subtle">Previous</span>
            <span class="font-display text-lg font-semibold">{prev.data.title}</span>
          </span>
        </a>
        <a
          href={`/work/${next.id}`}
          class="group flex items-center justify-end gap-3 py-8 pl-6 text-right transition-colors hover:text-primary"
        >
          <span>
            <span class="block font-mono text-xs uppercase tracking-widest text-text-subtle">Next</span>
            <span class="font-display text-lg font-semibold">{next.data.title}</span>
          </span>
          <Icon name="chevron-right" size={20} class="text-text-subtle transition-transform group-hover:translate-x-1" />
        </a>
      </Container>
    </nav>
  </article>
</BaseLayout>
