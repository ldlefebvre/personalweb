---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
---

<BaseLayout title="Page not found" noindex>
  <section class="container-page grid min-h-[60vh] place-items-center py-24 text-center">
    <div>
      <p class="font-mono text-sm uppercase tracking-[0.2em] text-primary">404</p>
      <h1 class="mt-4 text-h1">This page wandered off.</h1>
      <p class="mx-auto mt-4 max-w-md text-text-muted">
        The page you're looking for doesn't exist or may have moved.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button href="/" size="lg">Back home</Button>
        <Button href="/work" variant="secondary" size="lg">
          See my work <Icon name="arrow-right" size={18} />
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
