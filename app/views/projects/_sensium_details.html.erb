  # captions mirrored from Sensium's docs/ops/SCREENSHOT_PLAN.md.
  sensium_store_states = [
    ["store_01_train_home.png", "Train — daily drills"],
    ["store_02_train_active_recall.png", "Active recall"],
    ["store_03_grapes_search_recent.png", "Grapes — search & focus"],
    ["store_04_grape_detail_scan_first.png", "Scan-first dossier"],
    ["store_05_compare_fast_call.png", "Compare — Fast Call"],
    ["store_06_blind_coach_tools.png", "Blind — coach tools"],
    ["store_07_blind_aroma_learning.png", "Aroma → grape"],
    ["store_08_blind_process_learning.png", "Process glossary"],
    ["store_09_blind_region_learning.png", "Region narrowing"],
    ["store_10_paywall.png", "Premium"]
