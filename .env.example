# ---- Frontend (Astro) ----
# Cloudflare Turnstile *site* key (public). When set, the contact form renders
# the Turnstile widget and requires a token before submitting.
PUBLIC_TURNSTILE_SITE_KEY=

# ---- Backend (functions/) ----
# These are set as Firebase secrets, not committed:
#   firebase functions:secrets:set RESEND_API_KEY
#   firebase functions:secrets:set TURNSTILE_SECRET_KEY
# And as function env (functions/.env or deploy config):
#   CONTACT_TO=laurent.d.lefebvre@gmail.com
#   CONTACT_FROM=Portfolio Contact <noreply@laurentlefebvre.me>
